# AI Document Hub — Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_document_hub

# LLM — Get free API key at console.groq.com
GROQ_API_KEY=

# OCR fallback — Get free 1k/month at console.cloud.google.com
GOOGLE_VISION_API_KEY=

# Security
SECRET_KEY=change-me-to-a-random-32-char-string

# Redis
REDIS_URL=redis://localhost:6379

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Lightsail deployment)
LIGHTSAIL_HOST=
LIGHTSAIL_SSH_KEY=
GHCR_REPO=phananh1001/ai-classification
IMAGE_TAG=latest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
