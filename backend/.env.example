# =============================================================================
# AI Kế Toán - Go Backend Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Server ---
PORT=8080

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_ke_toan?sslmode=disable

# --- Auth ---
JWT_SECRET=your-secret-key-min-32-chars-long-here

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- OCR Provider ---
# Options: mock (dev/CI) | google_vision (free 1000/month) | viettel (VN, contact viettelai@viettel.com.vn) | fpt (VN invoices)
OCR_PROVIDER=mock
OCR_API_KEY=your-ocr-api-key

# --- MISA AMIS API ---
MISA_API_URL=https://api.misa.com.vn
MISA_API_KEY=your-misa-api-key

# --- Sentry ---
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# --- Email ---
RESEND_API_KEY=re_your-resend-key
